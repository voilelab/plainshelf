{
  "name": "plainshelf",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "sidecar:build": "node electron/build-sidecar.cjs",
    "electron:dev": "npm run build && npm run sidecar:build && npx --yes electron@^38 electron/main.cjs",
    "build:app": "vue-tsc --noEmit && vite build --outDir dist-app"
  },
  "dependencies": {
    "vue": "^3.5.12",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@vitejs/plugin-vue": "^5.1.4",
    "electron": "^38.8.6",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vue-tsc": "^2.1.6"
  },
  "build": {
    "asarUnpack": [
      "electron/plainshelf-gui-sidecar*"
    ]
  },
  "main": "electron/main.cjs"
}
